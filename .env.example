# ============================================
# ENVIRONMENT CONFIGURATION - Production Ready Setup
# ============================================
# This file documents ALL environment variables used in the monorepo.
# Copy this file to .env and fill in your actual values.
# Never commit .env to git - only .env.example
#
# See apps/api/.env.example and apps/web/.env.example for app-specific required vars

# ============================================
# DATABASE (Required for all apps)
# ============================================
DATABASE_URL="postgresql://user:password@localhost:5432/excalidraw"

# ============================================
# AUTHENTICATION - Clerk (Required for all apps)
# ============================================
# Get these from https://dashboard.clerk.com
CLERK_SECRET_KEY=sk_test_xxxxx
NEXT_PUBLIC_CLERK_PUBLISHABLE_KEY=pk_test_xxxxx

# ============================================
# API SERVER Configuration (Required for backend)
# ============================================
API_PORT=3001
API_URL=http://localhost:3001
# For frontend consumption
NEXT_PUBLIC_API_URL=http://localhost:3001

# ============================================
# INNGEST - Event Processing (Optional for backend)
# ============================================
# Get these from https://app.inngest.com
INNGEST_EVENT_KEY=your_key_here
INNGEST_SIGNING_KEY=your_signing_key_here

# ============================================
# PUBLISHING SERVICE - Cloudflare R2 (Optional)
# ============================================
# Uncomment if using publishing service
# Get these from https://dash.cloudflare.com
R2_ACCOUNT_ID=your_account_id
R2_ACCESS_KEY_ID=your_access_key_id
R2_SECRET_ACCESS_KEY=your_secret_key
R2_BUCKET_NAME=published-sites
R2_PUBLIC_URL=https://your-domain.r2.dev

# ============================================
# PUBLISHING SERVICE - Configuration (Optional)
# ============================================
PUBLISH_BASE_DOMAIN=yourdomain.com
MAX_BUNDLE_SIZE=52428800
MAX_BUILD_TIME_MS=30000
MAX_FILES_PER_PROJECT=500

# ============================================
# REDIS - Cache & Queue (Optional)
# ============================================
REDIS_HOST=localhost
REDIS_PORT=6379
# REDIS_PASSWORD=your_password  # Uncomment if Redis needs authentication
