# ============================================
# API SERVER - Required Environment Variables
# ============================================
# Copy this to .env and fill in your values
# These variables are required for API to run

# ============================================
# DATABASE (Shared with all apps)
# ============================================
DATABASE_URL="postgresql://user:password@localhost:5432/excalidraw"

# ============================================
# AUTHENTICATION - Clerk (Shared with all apps)
# ============================================
CLERK_SECRET_KEY=sk_test_xxxxx
NEXT_PUBLIC_CLERK_PUBLISHABLE_KEY=pk_test_xxxxx

# ============================================
# API SERVER Configuration
# ============================================
API_PORT=3001
API_URL=http://localhost:3001

# ============================================
# EVENT PROCESSING - Inngest
# ============================================
INNGEST_EVENT_KEY=your_event_key_here
INNGEST_SIGNING_KEY=your_signing_key_here

# ============================================
# PUBLISHING SERVICE (If enabled)
# ============================================
# Cloudflare R2 Configuration
R2_ACCOUNT_ID=your_account_id
R2_ACCESS_KEY_ID=your_access_key
R2_SECRET_ACCESS_KEY=your_secret_key
R2_PUBLIC_URL=https://your-domain.r2.dev

# Redis for caching and queues
REDIS_HOST=localhost
REDIS_PORT=6379
